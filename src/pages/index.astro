---
import PostCard from "@components/PostCard.astro";
import CardGroup from "@components/temple/CardGroup.astro";
import MainCard from "@/components/MainCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getAllPosts, getPostsWithStats, sortPostsByPinAndDate } from "@utils/blogUtils";

const allPosts = await getAllPosts();
const sortedPosts = sortPostsByPinAndDate(allPosts);
const latestPosts = await getPostsWithStats(sortedPosts.slice(0, 5));
---

<BaseLayout title="Home">
  <MainCard
    title="NullSet's Blog"
    description="记录学习与思考"
    image = "/home.webp"
    infoIcon="lucide:info"
  >
    <div class="space-y-6">
      <!-- Recent Posts Header -->
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <Icon name="lucide:clock" class="w-6 h-6 text-primary" />
          <span>最近文章</span>
        </h2>
        <a href="/blog" class="btn btn-sm btn-ghost gap-1">
          <span>全部文章</span>
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>

      <!-- Recent Posts -->
      <CardGroup cols="1">
        {
          latestPosts.map((blog) => (
            <PostCard
              title={blog.data.title}
              image={blog.data.image}
              description={blog.data.description}
              url={"/blog/" + blog.slug}
              pubDate={blog.data.pubDate}
              badge={blog.data.badge}
              categories={blog.data.categories}
              tags={blog.data.tags}
              word={blog.remarkPluginFrontmatter.totalCharCount}
              time={blog.remarkPluginFrontmatter.readingTime}
            />
          ))
        }
      </CardGroup>
    </div>
  </MainCard>
</BaseLayout>
